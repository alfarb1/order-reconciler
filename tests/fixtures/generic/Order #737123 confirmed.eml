/* What it does: Remove spaces around the email design
added by some email clients. */
/* Beware: It can remove the padding / Margin and add a
background color to the compose a reply window. */
html, body {
Margin: 0 auto !important;
padding: 0 !important;
width: 100% !important;
}
/* What it does: Stops email clients resizing small text.
*/
* {
-ms-text-size-adjust: 100%;
-webkit-text-size-adjust: 100%;
text-rendering: optimizeLegibility;
}
/* What it does: Forces Outlook.com to display emails
full width. */
.ExternalClass {
width: 100%;
}
/* What is does: Centers email on Android 4.4 */
div[style*=3D"Margin: 16px 0"] {
Margin:0 !important;
